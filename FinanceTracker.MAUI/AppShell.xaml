<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="FinanceTracker.MAUI.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:FinanceTracker.MAUI.Views">

    <TabBar>
        <ShellContent Title="Transactions"
                      Icon="tab_transactions.svg"
                      ContentTemplate="{DataTemplate views:TransactionListPage}"
                      Route="transactionlist"/>
        <ShellContent Title="Categories"
                      Icon="tab_categories.svg"
                      ContentTemplate="{DataTemplate views:CategoryListPage}"
                      Route="categorylist"/>
        <ShellContent Title="Analytics"
                      Icon="tab_analytics.svg"
                      ContentTemplate="{DataTemplate views:AnalyticsPage}"
                      Route="analytics"/>
    </TabBar>

</Shell>
