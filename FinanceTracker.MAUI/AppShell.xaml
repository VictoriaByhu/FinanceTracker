<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="FinanceTracker.MAUI.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:FinanceTracker.MAUI.Views">

    <TabBar>
        <ShellContent Title="Транзакції"
                      Icon="💸"
                      ContentTemplate="{DataTemplate views:TransactionListPage}"
                      Route="transactionlist"/>
        <ShellContent Title="Категорії"
                      Icon="🗂️"
                      ContentTemplate="{DataTemplate views:CategoryListPage}"
                      Route="categorylist"/>
    </TabBar>

</Shell>