<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.CategoryFormPage"
             Title="{Binding Title}"
             BackgroundColor="#0F2F28">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <VerticalStackLayout Spacing="6">
                <Label Text="Category name" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#173D34"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <Entry Text="{Binding Name}"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           PlaceholderColor="#6B7280"
                           Placeholder="For example: Food, Salary..."
                           FontSize="15"
                           Margin="12,8"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Category type" FontSize="13" TextColor="#9CA3AF"/>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            BackgroundColor="#3D1A1A"
                            Stroke="#E24B4A"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                        <RadioButton Content="Expense"
                                     GroupName="CategoryType"
                                     IsChecked="{Binding IsExpense, Mode=TwoWay}"
                                     TextColor="White"
                                     Padding="10,8"/>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#1A3D2E"
                            Stroke="#1D9E75"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                        <RadioButton Content="Income"
                                     GroupName="CategoryType"
                                     IsChecked="{Binding IsIncome, Mode=TwoWay}"
                                     TextColor="White"
                                     Padding="10,8"/>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Color" FontSize="13" TextColor="#9CA3AF"/>
                <FlexLayout Wrap="Wrap" JustifyContent="Start">

                    <BindableLayout.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>#1D9E75</x:String>
                            <x:String>#E24B4A</x:String>
                            <x:String>#7DD3B0</x:String>
                            <x:String>#EF9F27</x:String>
                            <x:String>#3B82F6</x:String>
                            <x:String>#EC4899</x:String>
                            <x:String>#10B981</x:String>
                            <x:String>#F97316</x:String>
                        </x:Array>
                    </BindableLayout.ItemsSource>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Grid WidthRequest="38"
                                  HeightRequest="38"
                                  Margin="5">
                                <Ellipse WidthRequest="28"
                                         HeightRequest="28"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                                    <Ellipse.Fill>
                                        <Binding Converter="{StaticResource StringToColorConverter}"/>
                                    </Ellipse.Fill>
                                </Ellipse>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectColorCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>

                </FlexLayout>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Preview" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#173D34"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12" ColumnSpacing="12">
                        <Ellipse Grid.Column="0"
                                 WidthRequest="10"
                                 HeightRequest="10"
                                 VerticalOptions="Center">
                            <Ellipse.Fill>
                                <Binding Path="BindingContext.SelectedColor"
                                         Source="{RelativeSource AncestorType={x:Type ContentPage}}"
                                         Converter="{StaticResource StringToColorConverter}"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Label Grid.Column="1"
                               Text="{Binding Name}"
                               FontSize="14"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2"
                               Text="{Binding TypePreview}"
                               FontSize="12"
                               TextColor="#9CA3AF"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <Border IsVisible="{Binding HasError}"
                    BackgroundColor="#3D1A1A"
                    Stroke="#E24B4A"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="12,10">
                <Label Text="{Binding ErrorMessage}"
                       FontSize="13"
                       TextColor="#FCA5A5"
                       LineBreakMode="WordWrap"/>
            </Border>

            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#2FAF7A"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="52"
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,8,0,0"/>

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="#1D493F"
                    TextColor="#9CA3AF"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="52"
                    IsEnabled="{Binding IsNotBusy}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
