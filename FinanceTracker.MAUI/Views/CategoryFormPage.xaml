<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.CategoryFormPage"
             Title="{Binding Title}"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Назва категорії"
                   TextColor="White" FontAttributes="Bold"/>
            <Entry Text="{Binding Name, Mode=TwoWay}"
                   Placeholder="Наприклад: Їжа, Зарплата..."
                   PlaceholderColor="#555555"
                   TextColor="White"
                   BackgroundColor="#16213E"/>

            <Label Text="Тип категорії"
                   TextColor="White" FontAttributes="Bold"/>
            <Grid ColumnDefinitions="Auto, *">
                <Switch Grid.Column="0"
                        IsToggled="{Binding IsIncome, Mode=TwoWay}"
                        OnColor="#4CAF50"/>
                <Label Grid.Column="1"
                       Text="Дохід (вимкнено = витрата)"
                       TextColor="#888888"
                       VerticalOptions="Center"
                       Margin="10,0"/>
            </Grid>

            <Button Text="Зберегти"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    Margin="0,20,0,0"/>

            <Button Text="Скасувати"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="#333333"
                    TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>