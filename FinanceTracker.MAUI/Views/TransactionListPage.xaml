<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.TransactionListPage"
             Title="Finance Tracker"
             BackgroundColor="#1A1A2E">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Command="{Binding GoToAddCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Верхня картка з балансом -->
        <Frame Grid.Row="0" Margin="15,15,15,5" Padding="20"
               BackgroundColor="#16213E" CornerRadius="20" HasShadow="True">
            <VerticalStackLayout Spacing="5">
                <Label Text="Загальний баланс"
                       TextColor="#888888"
                       FontSize="14"
                       HorizontalOptions="Center" />
                <Label Text="{Binding TotalBalance, StringFormat='₴{0:N2}'}"
                       TextColor="White"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
                    <Frame Grid.Column="0" BackgroundColor="#0F3460"
                           CornerRadius="12" Padding="10" Margin="0,0,5,0">
                        <VerticalStackLayout>
                            <Label Text="Доходи" TextColor="#4CAF50"
                                   FontSize="12" HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalIncome, StringFormat='₴{0:N2}'}"
                                   TextColor="White" FontAttributes="Bold"
                                   FontSize="16" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="1" BackgroundColor="#0F3460"
                           CornerRadius="12" Padding="10" Margin="5,0,0,0">
                        <VerticalStackLayout>
                            <Label Text="Витрати" TextColor="#F44336"
                                   FontSize="12" HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalExpenses, StringFormat='₴{0:N2}'}"
                                   TextColor="White" FontAttributes="Bold"
                                   FontSize="16" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <!-- Заголовок списку -->
        <Label Grid.Row="1" Text="Транзакції"
               TextColor="White" FontSize="18"
               FontAttributes="Bold" Margin="20,10,0,5" />

        <!-- Список транзакцій -->
        <RefreshView Grid.Row="2"
                     Command="{Binding LoadTransactionsCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Transactions}"
                            SelectionMode="Single"
                            SelectionChangedCommand="{Binding GoToDetailCommand}"
                            SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                        VerticalOptions="Center" Spacing="10"
                                        Margin="0,50,0,0">
                        <Label Text="💸" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="Транзакцій ще немає"
                               TextColor="#888888" FontSize="16"
                               HorizontalOptions="Center"/>
                        <Label Text="Натисніть + щоб додати"
                               TextColor="#555555" FontSize="14"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="15,5" Padding="15"
                               BackgroundColor="#16213E"
                               CornerRadius="15" HasShadow="True">
                            <Grid ColumnDefinitions="Auto, *, Auto">

                                <Frame Grid.Column="0"
                                       BackgroundColor="#0F3460"
                                       CornerRadius="22"
                                       WidthRequest="44" HeightRequest="44"
                                       Padding="0" HasShadow="False">
                                    <Label FontSize="20"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding IsIncome}"
                                                         Value="True">
                                                <Setter Property="Text" Value="💰"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding IsIncome}"
                                                         Value="False">
                                                <Setter Property="Text" Value="💸"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1"
                                                     Margin="12,0" Spacing="3">
                                    <Label Text="{Binding Description}"
                                           TextColor="White"
                                           FontSize="15"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding Date, StringFormat='{0:dd.MM.yyyy}'}"
                                           TextColor="#888888"
                                           FontSize="12" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsIncome}"
                                                     Value="True">
                                            <Setter Property="TextColor" Value="#4CAF50"/>
                                            <Setter Property="Text" Value="{Binding Amount, StringFormat='+₴{0:N0}'}"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsIncome}"
                                                     Value="False">
                                            <Setter Property="TextColor" Value="#F44336"/>
                                            <Setter Property="Text" Value="{Binding Amount, StringFormat='-₴{0:N0}'}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>