<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.TransactionListPage"
             BackgroundColor="#12122A">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Command="{Binding GoToAddCommand}" Order="Primary"/>
    </ContentPage.ToolbarItems>

    <RefreshView Command="{Binding LoadTransactionsCommand}"
                 IsRefreshing="{Binding IsBusy}"
                 RefreshColor="#A78BFA">
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Balance card -->
                <Border Margin="12,12,12,0"
                        BackgroundColor="#16213E"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Padding="16,14" Spacing="12">

                        <Label Text="Загальний баланс"
                               FontSize="12" TextColor="#9CA3AF"
                               HorizontalOptions="Center"/>

                        <Label Text="{Binding TotalBalance, StringFormat='₴{0:N0}'}"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">

                            <!-- Income -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#1A3D2E"
                                    StrokeThickness="1" Stroke="#1D9E75"
                                    StrokeShape="RoundRectangle 10">
                                <VerticalStackLayout Padding="10,8" Spacing="3">
                                    <Label Text="↑ Доходи"
                                           FontSize="11" TextColor="#9CA3AF"/>
                                    <Label Text="{Binding TotalIncome, StringFormat='₴{0:N0}'}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="#1D9E75"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Expenses -->
                            <Border Grid.Column="1"
                                    BackgroundColor="#3D1A1A"
                                    StrokeThickness="1" Stroke="#E24B4A"
                                    StrokeShape="RoundRectangle 10">
                                <VerticalStackLayout Padding="10,8" Spacing="3">
                                    <Label Text="↓ Витрати"
                                           FontSize="11" TextColor="#9CA3AF"/>
                                    <Label Text="{Binding TotalExpenses, StringFormat='₴{0:N0}'}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="#E24B4A"/>
                                </VerticalStackLayout>
                            </Border>

                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Section header -->
                <Label Text="Транзакції"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="White"
                       Margin="16,16,16,8"/>

                <!-- Empty state -->
                <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                     HorizontalOptions="Center"
                                     Padding="0,40,0,0" Spacing="8">
                    <Label Text="💸" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Транзакцій ще немає"
                           FontSize="15" TextColor="#9CA3AF"
                           HorizontalOptions="Center"/>
                    <Label Text="Натисніть + щоб додати"
                           FontSize="13" TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Transaction list -->
                <CollectionView ItemsSource="{Binding Transactions}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,0,12,8">
                                <Border BackgroundColor="#16213E"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToDetailCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="44,*,Auto"
                                          Padding="12,11" ColumnSpacing="10">

                                        <!-- Icon with colored background -->
                                        <Border Grid.Column="0"
                                                WidthRequest="40" HeightRequest="40"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                BackgroundColor="{Binding IsIncome, Converter={StaticResource BoolToIncomeColorConverter}}"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding IsIncome, Converter={StaticResource BoolToIconConverter}}"
                                                   FontSize="18"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <!-- Category name + description • date -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             VerticalOptions="Center"
                                                             Spacing="3">
                                            <Label Text="{Binding Category.Name}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="White"
                                                   LineBreakMode="TailTruncation"/>
                                            <Label FontSize="11" TextColor="#9CA3AF">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Description}"/>
                                                        <Span Text=" • "/>
                                                        <Span Text="{Binding Date, StringFormat='{0:dd.MM}'}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </VerticalStackLayout>

                                        <!-- Amount -->
                                        <Label Grid.Column="2"
                                               FontSize="14" FontAttributes="Bold"
                                               VerticalOptions="Center"
                                               TextColor="{Binding IsIncome, Converter={StaticResource BoolToAmountColorConverter}}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsIncome}"
                                                             Value="True">
                                                    <Setter Property="Text"
                                                            Value="{Binding Amount, StringFormat='+₴{0:N0}'}"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsIncome}"
                                                             Value="False">
                                                    <Setter Property="Text"
                                                            Value="{Binding Amount, StringFormat='−₴{0:N0}'}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid HeightRequest="24"/>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
