<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.TransactionDetailPage"
             Title="{Binding Title}"
             BackgroundColor="#1A1A2E">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Редагувати" Command="{Binding GoToEditCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Main Info -->
            <Frame BackgroundColor="#16213E" CornerRadius="20" Padding="20">
                <VerticalStackLayout Spacing="15">

                    <Label Text="{Binding Transaction.Category.Name}"
                           TextColor="White"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>

                    <Label FontSize="36"
                           FontAttributes="Bold"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding Transaction.IsIncome}"
                                         Value="True">
                                <Setter Property="TextColor" Value="#4CAF50"/>
                                <Setter Property="Text" Value="{Binding Transaction.Amount, StringFormat='+₴{0:N2}'}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding Transaction.IsIncome}"
                                         Value="False">
                                <Setter Property="TextColor" Value="#F44336"/>
                                <Setter Property="Text" Value="{Binding Transaction.Amount, StringFormat='-₴{0:N2}'}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                </VerticalStackLayout>
            </Frame>

            <!-- Details -->
            <Frame BackgroundColor="#16213E" CornerRadius="15" Padding="20">
                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*, *">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Date" TextColor="#888888" FontSize="12"/>
                            <Label Text="{Binding Transaction.Date, StringFormat='{0:dd.MM.yyyy}'}"
                                   TextColor="White" FontSize="16" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Type" TextColor="#888888" FontSize="12"/>
                            <Label TextColor="White" FontSize="16" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding Transaction.IsIncome}"
                                                 Value="True">
                                        <Setter Property="Text" Value="💰 Income"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding Transaction.IsIncome}"
                                                 Value="False">
                                        <Setter Property="Text" Value="💸 Expense"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#333333"/>

                    <VerticalStackLayout>
                        <Label Text="Description" TextColor="#888888" FontSize="12"/>
                        <Label Text="{Binding Transaction.Description}"
                               TextColor="White" FontSize="16"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Button Text="Delete Transaction"
                    Command="{Binding DeleteCommand}"
                    BackgroundColor="#F44336"
                    TextColor="White"
                    CornerRadius="15"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>