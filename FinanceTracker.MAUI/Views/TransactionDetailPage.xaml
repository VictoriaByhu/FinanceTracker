<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.TransactionDetailPage"
             Title="{Binding Transaction.Description}"
             BackgroundColor="#12122A">

    <!-- Shell uses the native back button on this page. -->
    <!--
    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,0,8,0">
            <ImageButton Grid.Column="0"
                         Command="{Binding GoBackCommand}"
                         BackgroundColor="Transparent"
                         WidthRequest="36" HeightRequest="36">
                <ImageButton.Source>
                    <FontImageSource Glyph="←" Color="#A78BFA" Size="20"/>
                </ImageButton.Source>
            </ImageButton>
            <Label Grid.Column="1"
                   Text="{Binding Transaction.Description}"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>
    </Shell.TitleView>
    -->

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="10">

            <!-- Hero card -->
            <Border BackgroundColor="#16213E"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Padding="16,18" Spacing="10" HorizontalOptions="Center">

                    <Label Text="{Binding Transaction.Description}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <Label Text="{Binding AmountFormatted}"
                           FontSize="32" FontAttributes="Bold"
                           HorizontalOptions="Center">
                        <Label.TextColor>
                            <Binding Path="Transaction.IsIncome"
                                     Converter="{StaticResource BoolToAmountColorConverter}"/>
                        </Label.TextColor>
                    </Label>

                    <!-- Income/Expense badge -->
                    <Border StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            HorizontalOptions="Center"
                            Padding="12,5">
                        <Border.Stroke>
                            <Binding Path="Transaction.IsIncome"
                                     Converter="{StaticResource BoolToAmountColorConverter}"/>
                        </Border.Stroke>
                        <Border.BackgroundColor>
                            <Binding Path="Transaction.IsIncome"
                                     Converter="{StaticResource BoolToBadgeBgConverter}"/>
                        </Border.BackgroundColor>
                        <Label Text="{Binding TypeLabel}"
                               FontSize="12" FontAttributes="Bold">
                            <Label.TextColor>
                                <Binding Path="Transaction.IsIncome"
                                         Converter="{StaticResource BoolToAmountColorConverter}"/>
                            </Label.TextColor>
                        </Label>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Info grid -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">

                <!-- Date -->
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="#16213E"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,10">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Дата" FontSize="11" TextColor="#9CA3AF"/>
                        <Label Text="{Binding Transaction.Date, StringFormat='{0:dd.MM.yyyy}'}"
                               FontSize="14" TextColor="White" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Category -->
                <Border Grid.Row="0" Grid.Column="1"
                        BackgroundColor="#16213E"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,10">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Категорія" FontSize="11" TextColor="#9CA3AF"/>
                        <Label Text="{Binding Transaction.Category.Name}"
                               FontSize="14" TextColor="White" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Description full width -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        BackgroundColor="#16213E"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,10">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Опис" FontSize="11" TextColor="#9CA3AF"/>
                        <Label Text="{Binding Transaction.Description}"
                               FontSize="14" TextColor="White"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Edit button (primary) -->
            <Button Text="✏ Редагувати"
                    Command="{Binding GoToEditCommand}"
                    BackgroundColor="#7C3AED"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    CornerRadius="12"
                    HeightRequest="50"
                    IsEnabled="{Binding IsNotBusy}"/>

            <!-- Delete button (danger outline) -->
            <Border StrokeThickness="1"
                    Stroke="#E24B4A"
                    BackgroundColor="#3D1A1A"
                    StrokeShape="RoundRectangle 12">
                <Button Text="🗑 Видалити транзакцію"
                        Command="{Binding DeleteCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#E24B4A"
                        FontSize="15"
                        HeightRequest="50"
                        IsEnabled="{Binding IsNotBusy}"/>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
