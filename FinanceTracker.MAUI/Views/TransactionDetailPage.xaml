<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.TransactionDetailPage"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Редагувати" Command="{Binding GoToEditCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Опис" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding Transaction.Description}" FontSize="18" />

            <Label Text="Сума" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding Transaction.Amount, StringFormat='{0:C}'}"
                   FontSize="18" />

            <Label Text="Дата" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding Transaction.Date, StringFormat='{0:dd.MM.yyyy}'}"
                   FontSize="18" />

            <Label Text="Тип" FontAttributes="Bold" TextColor="Gray" />
            <Label Text="{Binding Transaction.IsIncome, StringFormat='Дохід: {0}'}"
                   FontSize="18" />

            <Button Text="Видалити"
                    Command="{Binding DeleteCommand}"
                    BackgroundColor="Red"
                    TextColor="White"
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>