<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.TransactionFormPage"
             Title="{Binding Title}"
             BackgroundColor="#12122A">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Category picker -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Категорія" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#16213E"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <Picker Title="Оберіть категорію"
                            TitleColor="#6B7280"
                            ItemsSource="{Binding Categories}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedCategory}"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            Margin="12,4"/>
                </Border>
            </VerticalStackLayout>

            <!-- Amount -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Сума" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#16213E"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <Entry Text="{Binding Amount}"
                           Keyboard="Numeric"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           PlaceholderColor="#6B7280"
                           Placeholder="0.00"
                           FontSize="15"
                           Margin="12,8"/>
                </Border>
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Опис (необов'язково)" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#16213E"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <Entry Text="{Binding Description}"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           PlaceholderColor="#6B7280"
                           Placeholder="Введіть опис"
                           FontSize="15"
                           Margin="12,8"/>
                </Border>
            </VerticalStackLayout>

            <!-- Date -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Дата" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#16213E"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <DatePicker Date="{Binding Date}"
                                Format="dd.MM.yyyy"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                Margin="12,8"/>
                </Border>
            </VerticalStackLayout>

            <!-- Type toggle -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Тип" FontSize="13" TextColor="#9CA3AF"/>
                <Border StrokeThickness="1"
                        StrokeShape="RoundRectangle 12">
                    <!-- Border stroke and bg change with IsIncome -->
                    <Border.Stroke>
                        <Binding Path="IsIncome"
                                 Converter="{StaticResource BoolToAmountColorConverter}"/>
                    </Border.Stroke>
                    <Border.BackgroundColor>
                        <Binding Path="IsIncome"
                                 Converter="{StaticResource BoolToBadgeBgConverter}"/>
                    </Border.BackgroundColor>

                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12" ColumnSpacing="10">
                        <!-- Icon -->
                        <Label Grid.Column="0"
                               Text="{Binding IsIncome, Converter={StaticResource BoolToIconConverter}}"
                               FontSize="18" VerticalOptions="Center"/>
                        <!-- Label -->
                        <Label Grid.Column="1"
                               Text="{Binding TypeLabel}"
                               FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center">
                            <Label.TextColor>
                                <Binding Path="IsIncome"
                                         Converter="{StaticResource BoolToAmountColorConverter}"/>
                            </Label.TextColor>
                        </Label>
                        <!-- Toggle switch -->
                        <Switch Grid.Column="2"
                                IsToggled="{Binding IsIncome}"
                                OnColor="#7C3AED"
                                ThumbColor="White"
                                VerticalOptions="Center"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Save button -->
            <Button Text="Зберегти"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#7C3AED"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="52"
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,8,0,0"/>

            <!-- Cancel button -->
            <Button Text="Скасувати"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="#1E1E3A"
                    TextColor="#9CA3AF"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="52"
                    IsEnabled="{Binding IsNotBusy}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
