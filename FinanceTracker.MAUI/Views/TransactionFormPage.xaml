<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.TransactionFormPage"
             Title="{Binding Title}"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Category" TextColor="White" FontAttributes="Bold"/>
            <Picker ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                    ItemDisplayBinding="{Binding Name}"
                    Title="Select Category"
                    TitleColor="#555555"
                    TextColor="White"
                    BackgroundColor="#16213E"/>

            <Label Text="Amount" TextColor="White" FontAttributes="Bold"/>
            <Entry Text="{Binding Amount, Mode=TwoWay}"
                   Keyboard="Numeric"
                   Placeholder="0.00"
                   PlaceholderColor="#555555"
                   TextColor="White"
                   BackgroundColor="#16213E"/>

            <Label Text="Description (optional)"
                   TextColor="White" FontAttributes="Bold"/>
            <Entry Text="{Binding Description, Mode=TwoWay}"
                   Placeholder="Enter description"
                   PlaceholderColor="#555555"
                   TextColor="White"
                   BackgroundColor="#16213E"/>

            <Label Text="Date" TextColor="White" FontAttributes="Bold"/>
            <DatePicker Date="{Binding Date, Mode=TwoWay}"
                        TextColor="White"
                        BackgroundColor="#16213E"/>

            <Label Text="Type" TextColor="White" FontAttributes="Bold"/>
            <Frame BackgroundColor="#16213E" CornerRadius="12" Padding="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           TextColor="#888888"
                           FontSize="14"
                           VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding IsIncome}"
                                         Value="True">
                                <Setter Property="Text" Value="💰 Income"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding IsIncome}"
                                         Value="False">
                                <Setter Property="Text" Value="💸 Expense"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding IsIncome, Mode=TwoWay}"
                            OnColor="#4CAF50"/>
                </Grid>
            </Frame>

            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    Margin="0,20,0,0"/>

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="#333333"
                    TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>