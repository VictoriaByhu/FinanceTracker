<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceTracker.MAUI.Views.TransactionFormPage"
             Title="{Binding Title}"
             BackgroundColor="#0F2F28">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <VerticalStackLayout Spacing="6">
                <Label Text="Category" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#173D34"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <Picker Title="Choose a category"
                            TitleColor="#6B7280"
                            ItemsSource="{Binding Categories}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedCategory}"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            Margin="12,4"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Type" FontSize="13" TextColor="#9CA3AF"/>
                <Border StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{Binding IsIncome, Converter={StaticResource BoolToAmountColorConverter}}"
                        BackgroundColor="{Binding IsIncome, Converter={StaticResource BoolToBadgeBgConverter}}">
                    <Grid ColumnDefinitions="Auto,*" Padding="14,12" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="{Binding IsIncome, Converter={StaticResource BoolToIconConverter}}"
                               FontSize="18"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding TypeLabel}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{Binding IsIncome, Converter={StaticResource BoolToAmountColorConverter}}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Amount" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#173D34"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <Entry Text="{Binding Amount}"
                           Keyboard="Numeric"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           PlaceholderColor="#6B7280"
                           Placeholder="0.00"
                           FontSize="15"
                           Margin="12,8"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Description (optional)" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#173D34"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <Entry Text="{Binding Description}"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           PlaceholderColor="#6B7280"
                           Placeholder="Enter a description"
                           FontSize="15"
                           Margin="12,8"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Date" FontSize="13" TextColor="#9CA3AF"/>
                <Border BackgroundColor="#173D34"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                    <DatePicker Date="{Binding Date}"
                                Format="dd.MM.yyyy"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                Margin="12,8"/>
                </Border>
            </VerticalStackLayout>

            <Border IsVisible="{Binding HasError}"
                    BackgroundColor="#3D1A1A"
                    Stroke="#E24B4A"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="12,10">
                <Label Text="{Binding ErrorMessage}"
                       FontSize="13"
                       TextColor="#FCA5A5"
                       LineBreakMode="WordWrap"/>
            </Border>

            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#2FAF7A"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="52"
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,8,0,0"/>

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="#1D493F"
                    TextColor="#9CA3AF"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="52"
                    IsEnabled="{Binding IsNotBusy}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
